<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shishu-Sneha"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginTop="40dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mother &amp; Infant Healthcare"
            android:textSize="18sp"
            android:textColor="#388E3C"
            android:layout_marginBottom="40dp"/>

        <Button
            android:id="@+id/btnMotherForm"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Mother Details Form"
            android:textSize="18sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnPrediction"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Health Prediction"
            android:textSize="18sp"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnVaccination"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Vaccination Reminder"
            android:textSize="18sp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/btnEmergency"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Emergency Call"
            android:textSize="18sp"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/btnGrowth"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Growth Chart"
            android:textSize="18sp"
            android:backgroundTint="#0288D1"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/btnFeeding"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Feeding Guide"
            android:textSize="18sp"
            android:backgroundTint="#FB8C00"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>